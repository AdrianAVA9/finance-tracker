{
  "name": "fintrack.client",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "npm run build-only && wrangler dev",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "eslint . --fix --cache",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "deploy": "npm run build-only && wrangler deploy",
    "pwa:apple-splash": "pwa-asset-generator ./src/assets/logo.png ./.pwa-splash-staging --splash-only --background #111317 --padding 36% --type jpg --quality 90 && node ./scripts/sync-apple-splash.mjs",
    "pwa:apple-icons": "pwa-asset-generator ./src/assets/logo.png ./.pwa-icon-staging --icon-only --background #111317 --padding 22% --type png && node ./scripts/sync-pwa-icons.mjs",
    "pwa:apple-assets": "npm run pwa:apple-splash && npm run pwa:apple-icons"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/manrope": "^5.2.8",
    "@fontsource-variable/material-symbols-outlined": "^5.2.42",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "axios": "^1.13.6",
    "pinia": "^3.0.4",
    "sass": "^1.97.3",
    "vue": "^3.5.26",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.30.0",
    "@tsconfig/node24": "^24.0.3",
    "@types/node": "^24.10.4",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^4.1.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.2",
    "eslint-plugin-vue": "~10.6.2",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.0",
    "npm-run-all2": "^8.0.4",
    "postcss": "^8.5.8",
    "pwa-asset-generator": "^8.1.4",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.3",
    "vite": "^7.3.0",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-vue-devtools": "^8.0.5",
    "vitest": "^4.1.0",
    "vue-tsc": "^3.2.2",
    "wrangler": "^4.76.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.1.0",
    "@rollup/rollup-linux-x64-musl": "^4.1.0"
  }
}
